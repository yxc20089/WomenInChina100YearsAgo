POSTGRES_PASSWORD=replace-with-a-local-secret
POSTGRES_PORT=54329
OPENSEARCH_PORT=9200
NEO4J_AUTH=neo4j/replace-with-a-local-secret
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

DATABASE_URL=postgresql://women_history:replace-with-a-local-secret@127.0.0.1:54329/women_history
OPENSEARCH_URL=http://127.0.0.1:9200
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-local-secret

# Optional OpenAI-compatible endpoint for cited research briefs and reviewed-claim scenes.
# A local Ollama endpoint typically uses http://127.0.0.1:11434/v1.
LLM_BASE_URL=
LLM_MODEL=
LLM_MODEL_REVISION=
LLM_API_KEY=

# Explicit data-egress consent for any non-loopback LLM endpoint (HTTPS only,
# redirects refused). Required before the openrouter semantic provider or any
# other remote endpoint may be used.
LLM_ALLOW_REMOTE=false

# API key for the semantic stage when config/pipeline-models.toml pins
# provider = "openrouter". Read from the environment only; never written into
# configuration, artifacts, or logs.
OPENROUTER_API_KEY=

# Optional credential for the loopback-only structured NER endpoint.
NER_LLM_API_KEY=

# Optional isolated LightRAG experiment server.
LIGHTRAG_URL=http://127.0.0.1:9621
LIGHTRAG_API_KEY=replace-with-a-local-experiment-secret
